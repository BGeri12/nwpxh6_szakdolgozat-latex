	keywords = {Camera, Distance estimation, Measurement output, Time-to-collision (TTC), Vehicle detection},
	pages = {483--491},
	file = {Full Text PDF:C\:\\Users\\GeriGép\\Zotero\\storage\\PCS2AIZL\\Han et al. - 2016 - Vehicle distance estimation using a mono-camera for FCWAEB systems.pdf:application/pdf},
