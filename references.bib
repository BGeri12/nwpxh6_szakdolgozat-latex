	pages = {tdac026},
	file = {Submitted Version:C\:\\Users\\GeriGép\\Zotero\\storage\\73M6LQJT\\Ma et al. - 2022 - Computer vision for road imaging and pothole detection a state-of-the-art review of systems and alg.pdf:application/pdf},
